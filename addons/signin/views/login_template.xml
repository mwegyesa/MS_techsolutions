<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Modern Login Page -->
    <template id="login_template" name="Custom Login Page">
        <html>
        <head>
            <title>Sign In - MS Tech Solutions</title>
            <meta charset="utf-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1"/>
            <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
            <style type="text/css"><![CDATA[
                @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600;700&display=swap');
                
                * {
                    margin: 0;
                    padding: 0;
                    box-sizing: border-box;
                }
                
                body {
                    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
                    min-height: 100vh;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: linear-gradient(135deg, #150f4b 0%, #0f0a3a 100%);
                    overflow-x: hidden;
                }
                
                .decoration {
                    position: fixed;
                    border-radius: 50%;
                    filter: blur(100px);
                    z-index: 0;
                }
                
                .decoration-1 {
                    top: -20%;
                    left: -20%;
                    width: 600px;
                    height: 600px;
                    background: #22c55e;
                    opacity: 0.2;
                }
                
                .decoration-2 {
                    bottom: -20%;
                    right: -20%;
                    width: 500px;
                    height: 500px;
                    background: #150f4b;
                    opacity: 0.3;
                }
                
                .decoration-3 {
                    top: 50%;
                    left: 50%;
                    transform: translate(-50%, -50%);
                    width: 800px;
                    height: 800px;
                    background: radial-gradient(circle, rgba(34, 197, 94, 0.1) 0%, transparent 70%);
                }
                
                .login-container {
                    position: relative;
                    z-index: 10;
                    width: 100%;
                    max-width: 450px;
                    padding: 20px;
                }
                
                .login-card {
                    background: rgba(255, 255, 255, 0.95);
                    backdrop-filter: blur(20px);
                    border-radius: 24px;
                    padding: 50px 40px;
                    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);
                }
                
                .login-header {
                    text-align: center;
                    margin-bottom: 40px;
                }
                
                .login-header i {
                    font-size: 3rem;
                    color: #22c55e;
                    margin-bottom: 15px;
                }
                
                .login-header h1 {
                    font-family: 'Playfair Display', Georgia, serif;
                    font-size: 2rem;
                    font-weight: 700;
                    color: #150f4b;
                    margin-bottom: 8px;
                }
                
                .login-header p {
                    color: #6b7280;
                    font-size: 0.95rem;
                }
                
                .form-group {
                    margin-bottom: 25px;
                }
                
                .form-group label {
                    display: block;
                    font-size: 0.9rem;
                    font-weight: 600;
                    color: #374151;
                    margin-bottom: 8px;
                }
                
                .form-group .input-wrapper {
                    position: relative;
                }
                
                .form-group .input-icon {
                    position: absolute;
                    left: 18px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #9ca3af;
                    font-size: 1.1rem;
                    transition: color 0.3s ease;
                }
                
                .form-group input {
                    width: 100%;
                    padding: 16px 18px 16px 50px;
                    border: 2px solid #e5e7eb;
                    border-radius: 12px;
                    font-size: 1rem;
                    font-family: 'Inter', sans-serif;
                    transition: all 0.3s ease;
                    background: #f9fafb;
                }
                
                .form-group input:focus {
                    outline: none;
                    border-color: #22c55e;
                    background: white;
                    box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.1);
                }
                
                .form-group input:focus + .input-icon,
                .form-group .input-wrapper:focus-within .input-icon {
                    color: #22c55e;
                }
                
                .form-group input::placeholder {
                    color: #9ca3af;
                }
                
                .alert {
                    background: rgba(239, 68, 68, 0.1);
                    border: 1px solid #ef4444;
                    color: #dc2626;
                    padding: 14px 18px;
                    border-radius: 12px;
                    margin-bottom: 25px;
                    font-size: 0.9rem;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                }
                
                .alert i {
                    font-size: 1.1rem;
                }
                
                .btn-submit {
                    width: 100%;
                    padding: 16px;
                    background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
                    color: white;
                    border: none;
                    border-radius: 12px;
                    font-size: 1.1rem;
                    font-weight: 600;
                    cursor: pointer;
                    transition: all 0.3s ease;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    gap: 10px;
                    box-shadow: 0 10px 30px rgba(34, 197, 94, 0.3);
                }
                
                .btn-submit:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 15px 40px rgba(34, 197, 94, 0.4);
                }
                
                .btn-submit:active {
                    transform: translateY(0);
                }
                
                .divider {
                    display: flex;
                    align-items: center;
                    margin: 30px 0;
                    gap: 15px;
                }
                
                .divider::before,
                .divider::after {
                    content: '';
                    flex: 1;
                    height: 1px;
                    background: #e5e7eb;
                }
                
                .divider span {
                    color: #9ca3af;
                    font-size: 0.85rem;
                }
                
                .signup-link {
                    text-align: center;
                }
                
                .signup-link p {
                    color: #6b7280;
                    font-size: 0.95rem;
                }
                
                .signup-link a {
                    color: #22c55e;
                    text-decoration: none;
                    font-weight: 600;
                    transition: color 0.3s ease;
                }
                
                .signup-link a:hover {
                    color: #16a34a;
                    text-decoration: underline;
                }
                
                .back-link {
                    text-align: center;
                    margin-top: 30px;
                }
                
                .back-link a {
                    color: #9ca3af;
                    text-decoration: none;
                    font-size: 0.9rem;
                    display: inline-flex;
                    align-items: center;
                    gap: 8px;
                    transition: color 0.3s ease;
                }
                
                .back-link a:hover {
                    color: #150f4b;
                }
                
                @media (max-width: 480px) {
                    .login-container {
                        padding: 15px;
                    }
                    
                    .login-card {
                        padding: 40px 25px;
                    }
                    
                    .login-header h1 {
                        font-size: 1.75rem;
                    }
                }
            ]]></style>
        </head>
        <body>
            <div class="decoration decoration-1"></div>
            <div class="decoration decoration-2"></div>
            <div class="decoration decoration-3"></div>
            
            <div class="login-container">
                <div class="login-card">
                    <div class="login-header">
                        <i class="fas fa-laptop-code"></i>
                        <h1>Welcome Back</h1>
                        <p>Sign in to MS Tech Solutions</p>
                    </div>
                    
                    <t t-if="error">
                        <div class="alert">
                            <i class="fas fa-exclamation-circle"></i>
                            <t t-esc="error"/>
                        </div>
                    </t>
                    
                    <form action="/my-signin/login" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        
                        <div class="form-group">
                            <label for="login">Email or Username</label>
                            <div class="input-wrapper">
                                <input type="text" name="login" id="login" 
                                       t-att-value="login if login else ''"
                                       placeholder="Enter your email or username"
                                       required="required"/>
                                <i class="fas fa-envelope input-icon"></i>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label for="password">Password</label>
                            <div class="input-wrapper">
                                <input type="password" name="password" id="password" 
                                       placeholder="Enter your password"
                                       required="required"/>
                                <i class="fas fa-lock input-icon"></i>
                            </div>
                        </div>
                        
                        <button type="submit" class="btn-submit">
                            <i class="fas fa-sign-in-alt"></i>
                            Sign In
                        </button>
                    </form>
                    
                    <div class="divider">
                        <span>or</span>
                    </div>
                    
                    <div class="signup-link">
                        <p>Don't have an account? <a href="/my-signin/signup">Create one</a></p>
                    </div>
                    
                    <div class="back-link">
                        <a href="/custom-home">
                            <i class="fas fa-arrow-left"></i>
                            Back to Home
                        </a>
                    </div>
                </div>
            </div>
        </body>
        </html>
    </template>

