<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="user_form_template" name="Create User">
        <html>
        <head>
            <title>Create User - MS Tech Solutions</title>
            <meta charset="utf-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1"/>
            <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
            <style type="text/css">
                * {
                    margin: 0;
                    padding: 0;
                    box-sizing: border-box;
                }
                
                body {
                    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
                    background: linear-gradient(135deg, #150f4b 0%, #0f0a3a 100%);
                    min-height: 100vh;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    padding: 20px;
                }
                
                .form-container {
                    background: white;
                    border-radius: 20px;
                    padding: 40px;
                    width: 100%;
                    max-width: 500px;
                    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
                }
                
                .form-header {
                    text-align: center;
                    margin-bottom: 30px;
                }
                
                .form-header i {
                    font-size: 3rem;
                    color: #3b82f6;
                    margin-bottom: 15px;
                }
                
                .form-header h1 {
                    font-family: 'Playfair Display', Georgia, serif;
                    color: #150f4b;
                    font-size: 1.8rem;
                    margin-bottom: 8px;
                }
                
                .form-header p {
                    color: #6b7280;
                    font-size: 0.95rem;
                }
                
                .form-group {
                    margin-bottom: 20px;
                }
                
                .form-group label {
                    display: block;
                    margin-bottom: 8px;
                    color: #374151;
                    font-weight: 600;
                    font-size: 0.9rem;
                }
                
                .form-group input {
                    width: 100%;
                    padding: 14px 16px;
                    border: 2px solid #e5e7eb;
                    border-radius: 12px;
                    font-size: 1rem;
                    transition: all 0.3s ease;
                    background: #f9fafb;
                }
                
                .form-group input:focus {
                    outline: none;
                    border-color: #3b82f6;
                    background: white;
                    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
                }
                
                .btn-submit {
                    width: 100%;
                    padding: 16px;
                    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
                    color: white;
                    border: none;
                    border-radius: 12px;
                    font-size: 1.1rem;
                    font-weight: 600;
                    cursor: pointer;
                    transition: all 0.3s ease;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    gap: 10px;
                }
                
                .btn-submit:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 10px 30px rgba(59, 130, 246, 0.3);
                }
                
                .btn-back {
                    display: inline-flex;
                    align-items: center;
                    gap: 8px;
                    color: #6b7280;
                    text-decoration: none;
                    margin-bottom: 20px;
                    font-size: 0.9rem;
                    transition: color 0.3s ease;
                }
                
                .btn-back:hover {
                    color: #150f4b;
                }
                
                .error-message {
                    background: rgba(239, 68, 68, 0.1);
                    color: #dc2626;
                    padding: 12px 16px;
                    border-radius: 10px;
                    margin-bottom: 20px;
                    font-size: 0.9rem;
                }
            </style>
        </head>
        <body>
            <div class="form-container">
                <a href="/my-dashboard#users" class="btn-back">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
                
                <div class="form-header">
                    <i class="fas fa-user-plus"></i>
                    <h1>Create New User</h1>
                    <p>Add a new user to your system</p>
                </div>
                
                <t t-if="error">
                    <div class="error-message">
                        <i class="fas fa-exclamation-circle"></i> <t t-esc="error"/>
                    </div>
                </t>
                
                <form action="/my-dashboard/user/save" method="POST">
                    <div class="form-group">
                        <label><i class="fas fa-user"></i> Full Name *</label>
                        <input type="text" name="name" required="true" placeholder="Enter full name"/>
                    </div>
                    
                    <div class="form-group">
                        <label><i class="fas fa-envelope"></i> Email Address *</label>
                        <input type="email" name="login" required="true" placeholder="Enter email address"/>
                    </div>
                    
                    <div class="form-group">
                        <label><i class="fas fa-envelope-open\"></i> Alternative Email</label>
                        <input type="email" name="email" placeholder="Enter alternative email (optional)"/>
                    </div>
                    
                    <button type="submit" class="btn-submit">
                        <i class="fas fa-user-plus"></i> Create User
                    </button>
                </form>
            </div>
        </body>
        </html>
    </template>
</odoo>
